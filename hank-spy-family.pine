//@version=5
indicator(title="HANK SMC Pro — SPY Family", shorttitle="SMC-SPY", overlay=true,
     max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// =====================================================================
// HANK SMC Pro — SPY Family (SPY / ES1! / MES1!)
// =====================================================================
// Standalone fork of smc-pro-futures.pine — created 2026-05-13 after the
// library-based approach hit a Pine Editor tier-gate (operator on free
// TradingView; "New Library" workflow not available). Three family
// scripts now duplicate the full logic. Trade-off: paste-and-go
// simplicity vs DRY. Bug fixes must be applied 3x by hand.
//
// Family scope: SPY equity options + S&P 500 futures (ES1!, MES1!).
// Paste on SPY / ES1! / MES1! charts. instrumentOverride below is
// restricted to the SPY-family allow-list to prevent mislabeling on the
// wrong chart (per 2026-05-12 syminfo mislabel observation).
//
// Defaults match smc-pro-futures.pine exactly — no per-family tuning
// yet. Calibration is a separate, post-validation task.
//
// ─── PATCH 2026-05-18 — Six 1M signal-gap fixes ─────────────────────
// §FIX1  TF-adaptive cooldown: ≤5M → 5 bars, else signalCooldown input.
//        Prevents 20-min signal blackout on fast timeframes.
// §FIX2  OB displacement multiplier: 1.5 → 0.8 on ≤5M (≤300s).
//        Allows OBs to form on smaller intraday candles.
// §FIX3  FVG mitigation: wick-through → close-through on both sides.
//        Keeps FVGs alive through pullback wicks; deletes only on close.
// §FIX4  Adaptive pivot: string-based TF detection (superseded by §FIX7).
// §FIX5  Live signal thresholds: ≤2M volMult→1.3, dispMult→1.0.
//        Restores live markers on sub-3M timeframes without noise risk.
// §FIX6  Zone-break rejection wick: 0.5×ATR → 0.25×ATR on ≤2M.
//        Enables zone-break path on intraday charts.
//
// ─── PATCH 2026-05-19 — Pivot lag + ROLLING_BO engine ────────────────
// §FIX7  timeframe.in_seconds() replaces all string-based TF detection.
//        Eliminates remaining confirmation lag on 1M/2M:
//          ≤120s (1M/2M)  → pivotLen=1  (lag: 6 bars → 2 bars)
//          ≤300s (3M/5M)  → pivotLen=2  (lag: 10 bars → 4 bars)
//          >300s (10M+)   → pivotLen=3
//        Also extends 2M coverage across §FIX1/2/5/6 gates.
// §FIX8  ROLLING_BO engine: pivot-free breakout path.
//        rollingHigh/Low = ta.highest/lowest(close[1], 20).
//        Fires when close crosses 20-bar rolling extreme with volume ≥
//        1.3×SMA20. Zero pivot lag — fires at bar close only.
//        Bug-fixed: close[1] <= rollingHigh[1] (not rollingHigh) for
//        true first-bar detection.
// =====================================================================

// =====================================================================
// INPUTS
// =====================================================================

// --- General ---
gGeneral        = "General"
pivotLen        = input.int(2,        "Pivot length",            minval=1, maxval=50, group=gGeneral)
adaptivePivot   = input.bool(true,    "Adaptive pivot per TF",    group=gGeneral, tooltip="When ON: uses timeframe.in_seconds() — ≤120s→1, ≤300s→2, else→3. When OFF: uses 'Pivot length' input. (§FIX7: replaces string-based TF detection; adds 2M coverage; reduces 1M/2M lag to 2 bars.)")
sensitivity     = input.string("Balanced", "Signal sensitivity", options=["Conservative", "Balanced", "Aggressive"], group=gGeneral)
signalCooldown  = input.int(20,       "Signal cooldown (bars)",  minval=0, group=gGeneral, tooltip="Default applies to >5M. On ≤5M (≤300s) the script always uses 5 bars regardless of this value. (§FIX1/§FIX7)")
maxStructLabels = input.int(4,        "Max structure labels",    minval=1, maxval=20, group=gGeneral)

// --- Display ---
gDisplay      = "Display"
showStruct    = input.bool(true,  "Structure HH/HL/LH/LL labels", group=gDisplay)
showBOSLines  = input.bool(false, "BOS lines",                    group=gDisplay)
showCHoCHLines= input.bool(true,  "CHoCH lines",                  group=gDisplay)
showOBs       = input.bool(true,  "Order Blocks",                 group=gDisplay)
showFVGs      = input.bool(true,  "Fair Value Gaps",              group=gDisplay)
showSweeps    = input.bool(true,  "Liquidity Sweeps",             group=gDisplay)
showSignals   = input.bool(true,  "BUY / SELL signals",           group=gDisplay)
showSessions  = input.bool(true,  "Session zones",                group=gDisplay)

// --- Visual ---
gVisual      = "Visual"
zoneOpacity  = input.int(60, "Zone opacity (0=solid, 100=invisible)", minval=0, maxval=100, group=gVisual, tooltip="Fill transparency for supply/demand zones and order blocks (FVG + OB boxes). Lower = darker / more visible. Default 60 (was 88-92 hardcoded). Border thickness unchanged.")

// --- HTF & Dashboard ---
gHTF         = "HTF & Dashboard"
htfMode      = input.string("Auto", "HTF mode",        options=["Auto", "Manual"], group=gHTF)
htfManual    = input.timeframe("60", "HTF (Manual)",   group=gHTF)
htfPivotLen  = input.int(5,         "HTF pivot length", minval=2, maxval=50, group=gHTF)
useHTFFilter = input.bool(false,    "Filter signals by HTF bias", group=gHTF, tooltip="Only fire signals aligned with the HTF trend.")

// --- Zone-break signals (§10) ---
gZoneBreak       = "Zone-break signals"
enableZoneBreak  = input.bool(true,  "Enable zone-break signals",     group=gZoneBreak, tooltip="Fire BUY/SELL when price wicks into a zone and closes through to the opposite side (rejected supply/demand). Catches setups that the structural-break path misses.")
zbWickMult       = input.float(0.5,  "Rejection wick (× ATR)",        minval=0.0, step=0.05, group=gZoneBreak, tooltip="Minimum wick magnitude as fraction of ATR(14). Lower = more sensitive. On 1M/3M the script uses 0.25 regardless of this value (§FIX6).")

// --- Rolling Breakout engine (§FIX8) ---
gRBO            = "Rolling Breakout (ROLLING_BO)"
enableRBO       = input.bool(true,   "Enable ROLLING_BO engine",      group=gRBO, tooltip="Pivot-free breakout: fires when close crosses the 20-bar rolling high/low with volume confirmation. Zero pivot lag — complements the pivot-based BOS/CHoCH path. Best on 1M-5M.")
rboLookback     = input.int(20,      "Lookback (bars)",               minval=5, maxval=100, group=gRBO)
rboVolMult      = input.float(1.3,   "Volume multiplier (× SMA20)",   minval=0.5, step=0.1,  group=gRBO)
showRBOLabels   = input.bool(true,   "Show ▲▼ RBO labels on chart",   group=gRBO)

// --- Live intra-bar triggers (§12) ---
gLive             = "Live intra-bar triggers"
enableLiveSignals = input.bool(true,  "Enable LIVE intra-bar signals", group=gLive, tooltip="Fires hollow LIVE markers BEFORE bar close on displacement breaks with volume confirmation. Confirmed BUY/SELL still fires at close. Tune thresholds below if noisy.")
liveVolMult       = input.float(1.8,  "Volume spike (× SMA20)",        minval=0.5, step=0.1, group=gLive, tooltip="Higher = stricter. Tightened 2026-05-11 from 1.5 → 1.8 to suppress noise fires on intraday chop. On 1M/3M the script uses 1.3 (§FIX5).")
liveDispMult      = input.float(1.4,  "Displacement (× ATR)",          minval=0.5, step=0.1, group=gLive, tooltip="Higher = stricter. Tightened 2026-05-11 from 1.2 → 1.4 — only fire on clearly displaced bars. On 1M/3M the script uses 1.0 (§FIX5).")
liveExtremeRatio  = input.float(0.7,  "Close-near-extreme ratio",      minval=0.5, maxval=0.95, step=0.05, group=gLive, tooltip="Close must be in top/bottom (1 - ratio) of bar range. Higher = stricter.")

// --- Early-structure triggers (§14) ---
gEarly           = "Early-structure triggers"
enableHLBuy      = input.bool(true, "Enable HL→BUY / LH→SELL early-entry", group=gEarly, tooltip="Fire BUY when an HL pivot confirms above prior low; SELL when an LH pivot confirms below prior high. Catches continuation pullback completions AND early reversal turns. Subject to HTF filter, sensitivity gate, and cooldown.")

// --- Auto-recovery (§16/§17 Path C — undo trend mutation on false CHoCH) ---
gAutoRecovery       = "Auto-recovery"
enableAutoRecovery  = input.bool(true, "Enable auto-recovery on false CHoCH", group=gAutoRecovery, tooltip="When a CHoCH fires and within N bars price closes back through the broken pivot in the original direction, revert the trend state. Restores symmetry so the next legitimate signal can fire without waiting for HTF to catch up. Addresses §16 trend-state pollution and §17 HTF-filter collateral cost.")
autoRecoveryBars    = input.int(5, "Auto-recovery window (bars)", minval=1, maxval=20, group=gAutoRecovery, tooltip="Bars after CHoCH fire to check for price reclaim. 5 on 1M = 5 min window. Raise for longer windows on higher timeframes.")

// --- Webhook payload (instrument override for alert JSON) ---
gWebhook           = "Webhook Payload"
instrumentOverride = input.string("AUTO", "Instrument override", options=["AUTO","SPY","ES1!","MES1!"], group=gWebhook, tooltip="SPY-family allow-list. Default AUTO uses Pine's syminfo.ticker. Set explicitly per chart (SPY on SPY chart, ES1! on ES1! chart, etc.) to prevent the 2026-05-12 syminfo mislabel. Must match webhook-server.js VALID_INSTRUMENTS exactly.")

// --- Sessions (toggle each independently) ---
gSessions = "Sessions"
sAsia     = input.bool(true, "Asia 18:00-22:00 ET (Sun-Thu)",     group=gSessions)
sLondon   = input.bool(true, "London 03:00-05:00 ET",             group=gSessions)
sNYpre    = input.bool(true, "NY pre 07:00-09:30 ET",             group=gSessions)
sNYopen   = input.bool(true, "NY open 09:30-10:30 ET",            group=gSessions)
sNYclose  = input.bool(true, "NY close 16:00-16:15 ET",           group=gSessions)

// --- Colors ---
gColors    = "Colors"
clrBull    = input.color(#26C6DA,                "Bullish core",     group=gColors)
clrBear    = input.color(#EF5350,                "Bearish core",     group=gColors)
clrMuted   = input.color(#7F8FA0,                "Neutral / muted",  group=gColors)
clrAsia    = input.color(color.new(#9575CD, 96), "Asia zone",        group=gColors)
clrLondon  = input.color(color.new(#5C6BC0, 96), "London zone",      group=gColors)
clrNYpre   = input.color(color.new(#FFB74D, 96), "NY pre zone",      group=gColors)
clrNYopen  = input.color(color.new(#66BB6A, 95), "NY open zone",     group=gColors)
clrNYclose = input.color(color.new(#EF5350, 95), "NY close zone",    group=gColors)

// =====================================================================
// PIVOT BASELINE
// §FIX7: timeframe.in_seconds() replaces string-based TF detection.
//   ≤120s (1M/2M) → pivotLen=1  cuts lag to 2 bars (was 6)
//   ≤300s (3M/5M) → pivotLen=2  cuts lag to 4 bars (was 10)
//   >300s (10M+)  → pivotLen=3
// =====================================================================
pivotLenEff = adaptivePivot ?
     (timeframe.in_seconds() <= 120 ? 1 :
      timeframe.in_seconds() <= 300 ? 2 : 3) :
     pivotLen
ph    = ta.pivothigh(pivotLenEff, pivotLenEff)
pl    = ta.pivotlow(pivotLenEff,  pivotLenEff)
atr14 = ta.atr(14)

// =====================================================================
// STATE — structure tracking
// =====================================================================
var float prevSwingHigh     = na
var float prevSwingLow      = na
var float lastUnbrokenHigh  = na
var float lastUnbrokenLow   = na
var int   lastUnbrokenHiBar = na
var int   lastUnbrokenLoBar = na
var int   trend             = 0

var array<label> structLabels = array.new<label>()
var array<line>  bosLines    = array.new<line>()
var array<line>  chochLines  = array.new<line>()
var array<label> bosLabels   = array.new<label>()
var array<label> chochLabels = array.new<label>()

// =====================================================================
// STATE — order blocks, FVGs, sweeps
// =====================================================================
var array<box> bullOBs  = array.new<box>()
var array<box> bearOBs  = array.new<box>()
var array<box> bullFVGs = array.new<box>()
var array<box> bearFVGs = array.new<box>()

var int lastBullSweepBar = na
var int lastBearSweepBar = na
var array<label> sweepLabels = array.new<label>()

// =====================================================================
// STATE — signals
// =====================================================================
var int    lastBuyBar      = na
var int    lastSellBar     = na
var string lastSignalText  = "—"
var color  lastSignalColor = clrMuted

var bool   liveBullFiredThisBar = false
var bool   liveBearFiredThisBar = false
var bool   rboBullFiredThisBar  = false
var bool   rboBearFiredThisBar  = false

var float  falseBullCHOprice = na
var int    falseBullCHObar   = na
var float  falseBearCHOprice = na
var int    falseBearCHObar   = na

// =====================================================================
// STATE — sessions
// =====================================================================
var array<label> sessLabels = array.new<label>()

// =====================================================================
// HELPERS
// =====================================================================
pruneLabels(arr, maxN) =>
    while array.size(arr) > maxN
        old = array.shift(arr)
        label.delete(old)

pruneLines(arr, maxN) =>
    while array.size(arr) > maxN
        old = array.shift(arr)
        line.delete(old)

pruneBoxes(arr, maxN) =>
    while array.size(arr) > maxN
        old = array.shift(arr)
        box.delete(old)

// =====================================================================
// STRUCTURE — HH/HL/LH/LL labels
// =====================================================================
if not na(ph) and showStruct
    pivBar = bar_index - pivotLenEff
    txt    = na(prevSwingHigh) or ph > prevSwingHigh ? "HH" : "LH"
    col    = txt == "HH" ? clrBull : clrBear
    lbl    = label.new(x=pivBar, y=ph, text=txt, color=color.new(#000000, 100),
         textcolor=col, style=label.style_label_down, size=size.small,
         yloc=yloc.abovebar)
    array.push(structLabels, lbl)
    pruneLabels(structLabels, maxStructLabels * 2)

if not na(pl) and showStruct
    pivBar = bar_index - pivotLenEff
    txt    = na(prevSwingLow) or pl > prevSwingLow ? "HL" : "LL"
    col    = txt == "HL" ? clrBull : clrBear
    lbl    = label.new(x=pivBar, y=pl, text=txt, color=color.new(#000000, 100),
         textcolor=col, style=label.style_label_up, size=size.small,
         yloc=yloc.belowbar)
    array.push(structLabels, lbl)
    pruneLabels(structLabels, maxStructLabels * 2)

// §14 — early-structure raw signals (HL→BUY, LH→SELL)
bullHLraw = enableHLBuy and not na(pl) and not na(prevSwingLow)  and pl > prevSwingLow  and trend != -1
bearLHraw = enableHLBuy and not na(ph) and not na(prevSwingHigh) and ph < prevSwingHigh and trend != 1

if not na(ph)
    prevSwingHigh := ph
if not na(pl)
    prevSwingLow := pl

if not na(ph)
    lastUnbrokenHigh  := ph
    lastUnbrokenHiBar := bar_index - pivotLenEff
if not na(pl)
    lastUnbrokenLow  := pl
    lastUnbrokenLoBar := bar_index - pivotLenEff

// =====================================================================
// BOS / CHoCH detection (on confirmed bar close)
// =====================================================================
bullBOSraw = false
bearBOSraw = false
bullCHOraw = false
bearCHOraw = false

if barstate.isconfirmed
    if not na(lastUnbrokenHigh) and close > lastUnbrokenHigh
        if trend == -1
            bullCHOraw := true
            if enableAutoRecovery
                falseBullCHOprice := lastUnbrokenHigh
                falseBullCHObar   := bar_index
            trend := 1
        else
            bullBOSraw := true
            trend := 1
        if (bullBOSraw and showBOSLines) or (bullCHOraw and showCHoCHLines)
            ln = line.new(x1=lastUnbrokenHiBar, y1=lastUnbrokenHigh,
                 x2=bar_index, y2=lastUnbrokenHigh,
                 color=clrBull,
                 style=bullCHOraw ? line.style_solid : line.style_dashed,
                 width=1)
            lbl = label.new(x=bar_index, y=lastUnbrokenHigh,
                 text=bullCHOraw ? "CHoCH" : "BOS",
                 color=color.new(#000000, 100),
                 textcolor=clrBull, style=label.style_label_left,
                 size=size.tiny)
            if bullCHOraw
                array.push(chochLines, ln)
                array.push(chochLabels, lbl)
                pruneLines(chochLines, 12)
                pruneLabels(chochLabels, 12)
            else
                array.push(bosLines, ln)
                array.push(bosLabels, lbl)
                pruneLines(bosLines, 12)
                pruneLabels(bosLabels, 12)
        lastUnbrokenHigh  := na
        lastUnbrokenHiBar := na

    if not na(lastUnbrokenLow) and close < lastUnbrokenLow
        if trend == 1
            bearCHOraw := true
            if enableAutoRecovery
                falseBearCHOprice := lastUnbrokenLow
                falseBearCHObar   := bar_index
            trend := -1
        else
            bearBOSraw := true
            trend := -1
        if (bearBOSraw and showBOSLines) or (bearCHOraw and showCHoCHLines)
            ln = line.new(x1=lastUnbrokenLoBar, y1=lastUnbrokenLow,
                 x2=bar_index, y2=lastUnbrokenLow,
                 color=clrBear,
                 style=bearCHOraw ? line.style_solid : line.style_dashed,
                 width=1)
            lbl = label.new(x=bar_index, y=lastUnbrokenLow,
                 text=bearCHOraw ? "CHoCH" : "BOS",
                 color=color.new(#000000, 100),
                 textcolor=clrBear, style=label.style_label_left,
                 size=size.tiny)
            if bearCHOraw
                array.push(chochLines, ln)
                array.push(chochLabels, lbl)
                pruneLines(chochLines, 12)
                pruneLabels(chochLabels, 12)
            else
                array.push(bosLines, ln)
                array.push(bosLabels, lbl)
                pruneLines(bosLines, 12)
                pruneLabels(bosLabels, 12)
        lastUnbrokenLow  := na
        lastUnbrokenLoBar := na

// =====================================================================
// AUTO-RECOVERY (§16/§17 Path C)
// =====================================================================
if barstate.isconfirmed and enableAutoRecovery
    if not na(falseBullCHOprice) and (bar_index - falseBullCHObar) <= autoRecoveryBars
        if close < falseBullCHOprice
            trend := -1
            lastUnbrokenHigh  := falseBullCHOprice
            lastUnbrokenHiBar := falseBullCHObar - pivotLenEff
            falseBullCHOprice := na
            falseBullCHObar   := na

    if not na(falseBearCHOprice) and (bar_index - falseBearCHObar) <= autoRecoveryBars
        if close > falseBearCHOprice
            trend := 1
            lastUnbrokenLow  := falseBearCHOprice
            lastUnbrokenLoBar := falseBearCHObar - pivotLenEff
            falseBearCHOprice := na
            falseBearCHObar   := na

    if not na(falseBullCHObar) and (bar_index - falseBullCHObar) > autoRecoveryBars
        falseBullCHOprice := na
        falseBullCHObar   := na
    if not na(falseBearCHObar) and (bar_index - falseBearCHObar) > autoRecoveryBars
        falseBearCHOprice := na
        falseBearCHObar   := na

// =====================================================================
// LIQUIDITY SWEEPS
// =====================================================================
sweepThr     = 0.25 * atr14
bullSweepRaw = false
bearSweepRaw = false

if barstate.isconfirmed and not na(atr14)
    if not na(prevSwingLow) and low <= prevSwingLow - sweepThr and close > prevSwingLow
        bullSweepRaw := true
        lastBullSweepBar := bar_index
        if showSweeps
            lbl = label.new(x=bar_index, y=prevSwingLow,
                 text="◆", color=color.new(#000000, 100),
                 textcolor=clrBull, style=label.style_label_up,
                 size=size.tiny, yloc=yloc.belowbar)
            array.push(sweepLabels, lbl)
            pruneLabels(sweepLabels, 20)

    if not na(prevSwingHigh) and high >= prevSwingHigh + sweepThr and close < prevSwingHigh
        bearSweepRaw := true
        lastBearSweepBar := bar_index
        if showSweeps
            lbl = label.new(x=bar_index, y=prevSwingHigh,
                 text="◆", color=color.new(#000000, 100),
                 textcolor=clrBear, style=label.style_label_down,
                 size=size.tiny, yloc=yloc.abovebar)
            array.push(sweepLabels, lbl)
            pruneLabels(sweepLabels, 20)

// =====================================================================
// FAIR VALUE GAPS — 3-candle imbalance
// =====================================================================
fvgExtend = 80

if barstate.isconfirmed and not na(atr14) and showFVGs
    if high[2] < low[0]
        topY = low[0]
        botY = high[2]
        gap  = topY - botY
        if gap >= 0.3 * atr14
            b = box.new(left=bar_index - 2, top=topY,
                 right=bar_index + fvgExtend, bottom=botY,
                 bgcolor=color.new(clrBull, zoneOpacity),
                 border_color=color.new(clrBull, 80),
                 border_width=1)
            array.push(bullFVGs, b)
            pruneBoxes(bullFVGs, 3)

    if low[2] > high[0]
        topY = low[2]
        botY = high[0]
        gap  = topY - botY
        if gap >= 0.3 * atr14
            b = box.new(left=bar_index - 2, top=topY,
                 right=bar_index + fvgExtend, bottom=botY,
                 bgcolor=color.new(clrBear, zoneOpacity),
                 border_color=color.new(clrBear, 80),
                 border_width=1)
            array.push(bearFVGs, b)
            pruneBoxes(bearFVGs, 3)

// FVG mitigation — §FIX3: close-through only (was wick-through).
// Keeps FVGs alive during pullback wicks on 1M so nearBullZone resolves.
if barstate.isconfirmed and array.size(bullFVGs) > 0
    for i = array.size(bullFVGs) - 1 to 0
        b   = array.get(bullFVGs, i)
        bot = box.get_bottom(b)
        if close < bot        // §FIX3 was: low <= bot
            box.delete(b)
            array.remove(bullFVGs, i)

if barstate.isconfirmed and array.size(bearFVGs) > 0
    for i = array.size(bearFVGs) - 1 to 0
        b   = array.get(bearFVGs, i)
        top = box.get_top(b)
        if close > top        // §FIX3 was: high >= top
            box.delete(b)
            array.remove(bearFVGs, i)

// =====================================================================
// ORDER BLOCKS
// §FIX2: displacement multiplier is TF-adaptive.
//   1M/3M/5M → 0.8 × ATR (was hardcoded 1.5 × ATR).
//   Higher TFs keep 1.5 × ATR unchanged.
// =====================================================================
obExtend = 100

// §FIX2/§FIX7 — adaptive OB displacement via timeframe.in_seconds()
obDispMult   = timeframe.in_seconds() <= 300 ? 0.8 : 1.5

displacementBull = barstate.isconfirmed and not na(atr14) and close > open and (close - open) >= obDispMult * atr14
displacementBear = barstate.isconfirmed and not na(atr14) and close < open and (open - close) >= obDispMult * atr14

if displacementBull and showOBs
    int obIdx = na
    for k = 1 to 5
        if close[k] < open[k]
            obIdx := k
            break
    if not na(obIdx)
        b = box.new(left=bar_index - obIdx, top=high[obIdx],
             right=bar_index + obExtend, bottom=low[obIdx],
             bgcolor=color.new(clrBull, zoneOpacity),
             border_color=color.new(clrBull, 70),
             border_width=1)
        array.push(bullOBs, b)
        pruneBoxes(bullOBs, 2)

if displacementBear and showOBs
    int obIdx = na
    for k = 1 to 5
        if close[k] > open[k]
            obIdx := k
            break
    if not na(obIdx)
        b = box.new(left=bar_index - obIdx, top=high[obIdx],
             right=bar_index + obExtend, bottom=low[obIdx],
             bgcolor=color.new(clrBear, zoneOpacity),
             border_color=color.new(clrBear, 70),
             border_width=1)
        array.push(bearOBs, b)
        pruneBoxes(bearOBs, 2)

// OB mitigation — close through body → delete
if barstate.isconfirmed and array.size(bullOBs) > 0
    for i = array.size(bullOBs) - 1 to 0
        b   = array.get(bullOBs, i)
        bot = box.get_bottom(b)
        if close < bot
            box.delete(b)
            array.remove(bullOBs, i)

if barstate.isconfirmed and array.size(bearOBs) > 0
    for i = array.size(bearOBs) - 1 to 0
        b   = array.get(bearOBs, i)
        top = box.get_top(b)
        if close > top
            box.delete(b)
            array.remove(bearOBs, i)

// =====================================================================
// HTF BIAS
// =====================================================================
// §FIX7 — HTF auto-TF via timeframe.in_seconds()
htfTf = htfMode == "Auto" ?
     (timeframe.in_seconds() <= 300  ? "60"  :
      timeframe.in_seconds() <= 1800 ? "240" :
      timeframe.in_seconds() <= 7200 ? "D"   :
      "D") :
     htfManual

htfBiasFn() =>
    var array<float> hHs = array.new<float>()
    var array<float> hLs = array.new<float>()
    htfPh = ta.pivothigh(htfPivotLen, htfPivotLen)
    htfPl = ta.pivotlow(htfPivotLen,  htfPivotLen)
    if not na(htfPh)
        array.unshift(hHs, htfPh)
        if array.size(hHs) > 3
            array.pop(hHs)
    if not na(htfPl)
        array.unshift(hLs, htfPl)
        if array.size(hLs) > 3
            array.pop(hLs)
    bias = "Neutral"
    if array.size(hHs) >= 2 and array.size(hLs) >= 2
        hh = array.get(hHs, 0) > array.get(hHs, 1)
        hl = array.get(hLs, 0) > array.get(hLs, 1)
        ll = array.get(hLs, 0) < array.get(hLs, 1)
        lh = array.get(hHs, 0) < array.get(hHs, 1)
        bias := hh and hl ? "Bullish" : ll and lh ? "Bearish" : "Neutral"
    bias

htfBias = request.security(syminfo.tickerid, htfTf, htfBiasFn(),
     lookahead=barmerge.lookahead_off)

// =====================================================================
// ZONE-BREAK TRIGGERS (§10)
// §FIX6: rejection wick threshold is TF-adaptive.
//   1M/3M → 0.25 × ATR  (was zbWickMult = 0.5 × ATR)
//   Higher TFs use zbWickMult input unchanged.
// =====================================================================
bullZoneBreakRaw = false
bearZoneBreakRaw = false

// §FIX6/§FIX7 — adaptive zone-break wick threshold via timeframe.in_seconds()
tfZbWickMult = timeframe.in_seconds() <= 120 ? 0.25 : zbWickMult

if enableZoneBreak and barstate.isconfirmed and not na(atr14)
    if array.size(bullOBs) > 0
        for i = 0 to array.size(bullOBs) - 1
            b = array.get(bullOBs, i)
            zoneTop = box.get_top(b)
            touched  = low <= zoneTop
            brokeUp  = close > zoneTop
            rejected = (close - low) >= tfZbWickMult * atr14   // §FIX6
            if touched and brokeUp and rejected
                bullZoneBreakRaw := true
                break

    if array.size(bearOBs) > 0
        for i = 0 to array.size(bearOBs) - 1
            b = array.get(bearOBs, i)
            zoneBot = box.get_bottom(b)
            touched   = high >= zoneBot
            brokeDown = close < zoneBot
            rejected  = (high - close) >= tfZbWickMult * atr14  // §FIX6
            if touched and brokeDown and rejected
                bearZoneBreakRaw := true
                break

// =====================================================================
// LIVE INTRA-BAR TRIGGERS (§12)
// §FIX5: liveVolMult and liveDispMult are TF-adaptive on 1M/3M.
//   volMult:  1.8 → 1.3  on 1M/3M
//   dispMult: 1.4 → 1.0  on 1M/3M
// =====================================================================
if barstate.isnew
    liveBullFiredThisBar := false
    liveBearFiredThisBar := false

liveBullBreakRaw = false
liveBearBreakRaw = false

if enableLiveSignals and barstate.isrealtime and not na(atr14)
    // §FIX5/§FIX7 — TF-adaptive live thresholds via timeframe.in_seconds()
    tfLiveVolMult  = timeframe.in_seconds() <= 120 ? 1.3 : liveVolMult
    tfLiveDispMult = timeframe.in_seconds() <= 120 ? 1.0 : liveDispMult

    avgVol        = ta.sma(volume, 20)
    volSpike      = not na(avgVol) and volume >= tfLiveVolMult * avgVol   // §FIX5
    barRange      = high - low
    displaced     = barRange >= tfLiveDispMult * atr14                    // §FIX5
    closeNearHigh = barRange > 0 and (close - low) / barRange > liveExtremeRatio
    closeNearLow  = barRange > 0 and (high - close) / barRange > liveExtremeRatio

    if not liveBullFiredThisBar and not na(lastUnbrokenHigh) and close > lastUnbrokenHigh and volSpike and displaced and closeNearHigh
        liveBullBreakRaw      := true
        liveBullFiredThisBar  := true

    if not liveBearFiredThisBar and not na(lastUnbrokenLow) and close < lastUnbrokenLow and volSpike and displaced and closeNearLow
        liveBearBreakRaw      := true
        liveBearFiredThisBar  := true

// =====================================================================
// ROLLING BREAKOUT ENGINE (§FIX8)
// pivot-free: fires at bar close with zero pivot confirmation lag.
// rollingHigh/Low = confirmed 20-bar rolling extreme (close[1] offset).
// Bug-fix applied: close[1] <= rollingHigh[1] for true first-bar cross.
// =====================================================================
if barstate.isnew
    rboBullFiredThisBar := false
    rboBearFiredThisBar := false

rollingBullBO = false
rollingBearBO = false

if enableRBO and barstate.isconfirmed
    avgVol20   = ta.sma(volume, 20)
    rboVol     = not na(avgVol20) and volume >= avgVol20 * rboVolMult
    rollingHigh = ta.highest(close[1], rboLookback)
    rollingLow  = ta.lowest(close[1],  rboLookback)

    if close > rollingHigh and close[1] <= rollingHigh[1] and rboVol
        rollingBullBO := true
        rboBullFiredThisBar := true

    if close < rollingLow and close[1] >= rollingLow[1] and rboVol
        rollingBearBO := true
        rboBearFiredThisBar := true

// =====================================================================
// SIGNALS
// =====================================================================
RECENT_SWEEP_BARS = 10

bullBreak = bullBOSraw or bullCHOraw or bullZoneBreakRaw or bullHLraw
bearBreak = bearBOSraw or bearCHOraw or bearZoneBreakRaw or bearLHraw

bullSweepRecent = not na(lastBullSweepBar) and (bar_index - lastBullSweepBar) <= RECENT_SWEEP_BARS
bearSweepRecent = not na(lastBearSweepBar) and (bar_index - lastBearSweepBar) <= RECENT_SWEEP_BARS

nearBullZone = false
if not na(atr14)
    band = 0.5 * atr14
    if array.size(bullOBs) > 0
        for i = 0 to array.size(bullOBs) - 1
            b = array.get(bullOBs, i)
            t = box.get_top(b)
            bo = box.get_bottom(b)
            if low <= t + band and low >= bo - band
                nearBullZone := true
    if not nearBullZone and array.size(bullFVGs) > 0
        for i = 0 to array.size(bullFVGs) - 1
            b = array.get(bullFVGs, i)
            t = box.get_top(b)
            bo = box.get_bottom(b)
            if low <= t + band and low >= bo - band
                nearBullZone := true

nearBearZone = false
if not na(atr14)
    band = 0.5 * atr14
    if array.size(bearOBs) > 0
        for i = 0 to array.size(bearOBs) - 1
            b = array.get(bearOBs, i)
            t = box.get_top(b)
            bo = box.get_bottom(b)
            if high >= bo - band and high <= t + band
                nearBearZone := true
    if not nearBearZone and array.size(bearFVGs) > 0
        for i = 0 to array.size(bearFVGs) - 1
            b = array.get(bearFVGs, i)
            t = box.get_top(b)
            bo = box.get_bottom(b)
            if high >= bo - band and high <= t + band
                nearBearZone := true

buyTrigger = false
sellTrigger = false

if barstate.isconfirmed
    if sensitivity == "Conservative"
        buyTrigger  := (bullCHOraw and (bullSweepRecent or nearBullZone)) or
                       (bullBOSraw and bullSweepRecent and nearBullZone) or
                       bullZoneBreakRaw or
                       (bullHLraw and (bullSweepRecent or nearBullZone))
        sellTrigger := (bearCHOraw and (bearSweepRecent or nearBearZone)) or
                       (bearBOSraw and bearSweepRecent and nearBearZone) or
                       bearZoneBreakRaw or
                       (bearLHraw and (bearSweepRecent or nearBearZone))
    else if sensitivity == "Balanced"
        buyTrigger  := bullCHOraw or
                       (bullBOSraw and (bullSweepRecent or nearBullZone)) or
                       bullZoneBreakRaw or
                       bullHLraw
        sellTrigger := bearCHOraw or
                       (bearBOSraw and (bearSweepRecent or nearBearZone)) or
                       bearZoneBreakRaw or
                       bearLHraw
    else  // Aggressive
        buyTrigger  := bullBreak
        sellTrigger := bearBreak

    // §FIX1/§FIX7 — TF-adaptive cooldown via timeframe.in_seconds()
    // 2026-05-19 EOD: ≤300s reduced from 5 → 2 bars after operator's
    // 15:35 ES1!/MES1! PUTS LH + ZONE fired then Pine internally locked
    // out subsequent PUTS for 25 min (5 bars × 5M), missing a real put
    // continuation move that came in at 15:40-15:50. 2-bar cooldown on
    // ≤5M (10 min) better matches the chop tape rhythm.
    tfCooldown = timeframe.in_seconds() <= 300 ? 2 : signalCooldown

    if buyTrigger  and not na(lastBuyBar)  and (bar_index - lastBuyBar)  < tfCooldown
        buyTrigger  := false
    if sellTrigger and not na(lastSellBar) and (bar_index - lastSellBar) < tfCooldown
        sellTrigger := false

    // HTF filter
    if useHTFFilter
        if buyTrigger  and htfBias != "Bullish"
            buyTrigger  := false
        if sellTrigger and htfBias != "Bearish"
            sellTrigger := false

buyTriggerHTF  = buyTrigger  and htfBias == "Bullish"
sellTriggerHTF = sellTrigger and htfBias == "Bearish"

// Render BUY/SELL
if buyTrigger and showSignals
    yOff = na(atr14) ? 0.0 : atr14 * 0.5
    label.new(x=bar_index, y=low - yOff, text="BUY",
         color=color.new(clrBull, 0), textcolor=color.white,
         style=label.style_label_up, size=size.normal)
    lastBuyBar      := bar_index
    lastSignalText  := "BUY"
    lastSignalColor := clrBull

if sellTrigger and showSignals
    yOff = na(atr14) ? 0.0 : atr14 * 0.5
    label.new(x=bar_index, y=high + yOff, text="SELL",
         color=color.new(clrBear, 0), textcolor=color.white,
         style=label.style_label_down, size=size.normal)
    lastSellBar     := bar_index
    lastSignalText  := "SELL"
    lastSignalColor := clrBear

plotshape(buyTrigger  and showSignals, title="BUY arrow",  style=shape.triangleup,
     location=location.belowbar, color=clrBull, size=size.tiny)
plotshape(sellTrigger and showSignals, title="SELL arrow", style=shape.triangledown,
     location=location.abovebar, color=clrBear, size=size.tiny)

// §FIX8 — ROLLING_BO visual labels
if rollingBullBO and showRBOLabels
    yOff = na(atr14) ? 0.0 : atr14 * 0.7
    label.new(x=bar_index, y=low - yOff, text="▲ RBO",
         color=color.new(clrBull, 20), textcolor=color.white,
         style=label.style_label_up, size=size.tiny, yloc=yloc.belowbar)

if rollingBearBO and showRBOLabels
    yOff = na(atr14) ? 0.0 : atr14 * 0.7
    label.new(x=bar_index, y=high + yOff, text="▼ RBO",
         color=color.new(clrBear, 20), textcolor=color.white,
         style=label.style_label_down, size=size.tiny, yloc=yloc.abovebar)

plotshape(liveBullBreakRaw and showSignals, title="LIVE BUY",  style=shape.circle,
     location=location.belowbar, color=clrBull, size=size.tiny, text="L", textcolor=color.white)
plotshape(liveBearBreakRaw and showSignals, title="LIVE SELL", style=shape.circle,
     location=location.abovebar, color=clrBear, size=size.tiny, text="L", textcolor=color.white)

// =====================================================================
// SESSION ZONES
// =====================================================================
TZ = "America/New_York"
asiaSessStr    = "1800-2200:12345"
londonSessStr  = "0300-0500:23456"
nyPreSessStr   = "0700-0930:23456"
nyOpenSessStr  = "0930-1030:23456"
nyCloseSessStr = "1600-1615:23456"

inAsia    = sAsia    and not na(time(timeframe.period, asiaSessStr,    TZ))
inLondon  = sLondon  and not na(time(timeframe.period, londonSessStr,  TZ))
inNYpre   = sNYpre   and not na(time(timeframe.period, nyPreSessStr,   TZ))
inNYopen  = sNYopen  and not na(time(timeframe.period, nyOpenSessStr,  TZ))
inNYclose = sNYclose and not na(time(timeframe.period, nyCloseSessStr, TZ))

bgcolor(showSessions and inAsia    ? clrAsia    : na, title="Asia session")
bgcolor(showSessions and inLondon  ? clrLondon  : na, title="London session")
bgcolor(showSessions and inNYpre   ? clrNYpre   : na, title="NY pre session")
bgcolor(showSessions and inNYopen  ? clrNYopen  : na, title="NY open session")
bgcolor(showSessions and inNYclose ? clrNYclose : na, title="NY close session")

sessionEnter(curIn, prevIn, name, col) =>
    if curIn and not prevIn
        ph2 = ta.highest(20)
        lbl = label.new(x=bar_index, y=ph2, text=name,
             color=color.new(#000000, 100), textcolor=col,
             style=label.style_label_down, size=size.tiny,
             yloc=yloc.abovebar)
        array.push(sessLabels, lbl)
        pruneLabels(sessLabels, 25)

if showSessions
    sessionEnter(inAsia,    inAsia[1],    "Asia",     clrMuted)
    sessionEnter(inLondon,  inLondon[1],  "London",   clrMuted)
    sessionEnter(inNYpre,   inNYpre[1],   "NY pre",   clrMuted)
    sessionEnter(inNYopen,  inNYopen[1],  "NY open",  clrBull)
    sessionEnter(inNYclose, inNYclose[1], "NY close", clrBear)

curSessName =
     inAsia    ? "Asia"    :
     inLondon  ? "London"  :
     inNYpre   ? "NY pre"  :
     inNYopen  ? "NY open" :
     inNYclose ? "NY close" :
     "—"

// =====================================================================
// CDP POLLER COUNTERS — 2026-05-11 (v2 cumulative)
// =====================================================================
var int buyFireCount        = 0
var int sellFireCount       = 0
var int bullZoneBreakCount  = 0
var int bearZoneBreakCount  = 0
var int bullHLCount         = 0
var int bearLHCount         = 0
var int liveBuyCount        = 0
var int liveSellCount       = 0
var int rboBullCount        = 0
var int rboBearCount        = 0

if buyTrigger
    buyFireCount := buyFireCount + 1
if sellTrigger
    sellFireCount := sellFireCount + 1
if bullZoneBreakRaw
    bullZoneBreakCount := bullZoneBreakCount + 1
if bearZoneBreakRaw
    bearZoneBreakCount := bearZoneBreakCount + 1
if bullHLraw
    bullHLCount := bullHLCount + 1
if bearLHraw
    bearLHCount := bearLHCount + 1
if liveBullBreakRaw
    liveBuyCount := liveBuyCount + 1
if liveBearBreakRaw
    liveSellCount := liveSellCount + 1
if rollingBullBO
    rboBullCount := rboBullCount + 1
if rollingBearBO
    rboBearCount := rboBearCount + 1

plot(buyFireCount,        title="BuyFireCount",       color=color.new(color.green,  100), display=display.data_window)
plot(sellFireCount,       title="SellFireCount",      color=color.new(color.red,    100), display=display.data_window)
plot(bullZoneBreakCount,  title="BullZoneBreakCount", color=color.new(color.green,  100), display=display.data_window)
plot(bearZoneBreakCount,  title="BearZoneBreakCount", color=color.new(color.red,    100), display=display.data_window)
plot(bullHLCount,         title="BullHLCount",        color=color.new(color.green,  100), display=display.data_window)
plot(bearLHCount,         title="BearLHCount",        color=color.new(color.red,    100), display=display.data_window)
plot(liveBuyCount,        title="LiveBuyCount",       color=color.new(color.green,  100), display=display.data_window)
plot(liveSellCount,       title="LiveSellCount",      color=color.new(color.red,    100), display=display.data_window)
plot(rboBullCount,        title="RBOBullCount",       color=color.new(color.green,  100), display=display.data_window)
plot(rboBearCount,        title="RBOBearCount",       color=color.new(color.red,    100), display=display.data_window)

// =====================================================================
// ALERT() FUNCTION CALLS — autonomous execution arch
// =====================================================================
payloadJSON(direction, engine, confidence) =>
    instStr = instrumentOverride == "AUTO" ? syminfo.ticker : instrumentOverride
    invalLevel = direction == "CALLS" ? prevSwingLow : prevSwingHigh
    structType = direction == "CALLS" ? "HL" : "LH"
    invalStr   = na(invalLevel) ? "null" : str.tostring(invalLevel, "#.####")
    // 2026-05-19 — include chart timeframe so webhook can route by TF
    // (3M primary + 5M context per operator spec). Pine sends the bar
    // period in seconds; webhook normalizes to minutes for matching.
    tfStr      = str.tostring(timeframe.in_seconds() / 60, "#")
    '{"instrument":"' + instStr + '","direction":"' + direction +
      '","engine":"' + engine + '","confidence":"' + confidence +
      '","price":' + str.tostring(close, "#.##") +
      ',"tf":"' + tfStr + '"' +
      ',"invalidation_level":' + invalStr +
      ',"structure_type":"' + structType + '"' +
      ',"alertName":"' + engine + ' ' + direction + '"}'

if buyTrigger
    alert(payloadJSON('CALLS', 'BUY',  'MEDIUM'), alert.freq_once_per_bar_close)
if sellTrigger
    alert(payloadJSON('PUTS',  'SELL', 'MEDIUM'), alert.freq_once_per_bar_close)

if buyTriggerHTF
    alert(payloadJSON('CALLS', 'HTF',  'HIGH'), alert.freq_once_per_bar_close)
if sellTriggerHTF
    alert(payloadJSON('PUTS',  'HTF',  'HIGH'), alert.freq_once_per_bar_close)

if bullZoneBreakRaw
    alert(payloadJSON('CALLS', 'ZONE', 'MEDIUM'), alert.freq_once_per_bar_close)
if bearZoneBreakRaw
    alert(payloadJSON('PUTS',  'ZONE', 'MEDIUM'), alert.freq_once_per_bar_close)
if bullHLraw
    alert(payloadJSON('CALLS', 'HL',   'MEDIUM'), alert.freq_once_per_bar_close)
if bearLHraw
    alert(payloadJSON('PUTS',  'LH',   'MEDIUM'), alert.freq_once_per_bar_close)

if liveBullBreakRaw
    alert(payloadJSON('CALLS', 'LIVE', 'MEDIUM'), alert.freq_once_per_bar)
if liveBearBreakRaw
    alert(payloadJSON('PUTS',  'LIVE', 'MEDIUM'), alert.freq_once_per_bar)

// §FIX8 — ROLLING_BO alerts
if rollingBullBO
    alert(payloadJSON('CALLS', 'ROLLING_BO', 'MEDIUM'), alert.freq_once_per_bar_close)
if rollingBearBO
    alert(payloadJSON('PUTS',  'ROLLING_BO', 'MEDIUM'), alert.freq_once_per_bar_close)

// =====================================================================
// ALERT CONDITIONS — backward-compat
// =====================================================================
alertcondition(bullBOSraw,       "Bullish BOS",            "SMC: Bullish BOS")
alertcondition(bearBOSraw,       "Bearish BOS",            "SMC: Bearish BOS")
alertcondition(bullCHOraw,       "Bullish CHoCH",          "SMC: Bullish CHoCH (trend reversal up)")
alertcondition(bearCHOraw,       "Bearish CHoCH",          "SMC: Bearish CHoCH (trend reversal down)")
alertcondition(bullSweepRaw,     "Bullish Liquidity Sweep","SMC: Bullish liquidity sweep")
alertcondition(bearSweepRaw,     "Bearish Liquidity Sweep","SMC: Bearish liquidity sweep")
alertcondition(bullZoneBreakRaw, "Bullish Zone Break",     "SMC: Bullish zone-break rejection")
alertcondition(bearZoneBreakRaw, "Bearish Zone Break",     "SMC: Bearish zone-break rejection")
alertcondition(liveBullBreakRaw, "LIVE Bullish Break",     "SMC: LIVE bullish break (intra-bar)")
alertcondition(liveBearBreakRaw, "LIVE Bearish Break",     "SMC: LIVE bearish break (intra-bar)")
alertcondition(bullHLraw,        "Bullish HL early-entry", "SMC: Bullish HL pivot — early continuation/reversal entry")
alertcondition(bearLHraw,        "Bearish LH early-entry", "SMC: Bearish LH pivot — early continuation/reversal entry")
alertcondition(buyTrigger,       "BUY signal",             "SMC: BUY signal")
alertcondition(sellTrigger,      "SELL signal",            "SMC: SELL signal")
alertcondition(buyTriggerHTF,    "HTF-aligned BUY",        "SMC: HTF-aligned BUY")
alertcondition(sellTriggerHTF,   "HTF-aligned SELL",       "SMC: HTF-aligned SELL")
alertcondition(rollingBullBO,    "Rolling BO CALLS",       "SMC: Rolling breakout CALLS (§FIX8)")
alertcondition(rollingBearBO,    "Rolling BO PUTS",        "SMC: Rolling breakout PUTS (§FIX8)")
